{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "obsidian-guardrail",
            "type": "command",
            "command": "${extensionPath}/hooks/enforce-obsidian-writes.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "session-context",
            "type": "command",
            "command": "${extensionPath}/hooks/session-context.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "name": "compound-reminder",
            "type": "command",
            "command": "${extensionPath}/hooks/compound-reminder.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
